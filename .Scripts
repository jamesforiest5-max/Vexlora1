ExploitsTab:Toggle({
	Title = "AutoFarm Energy",
	Value = false,
	Callback = function(state)
		getgenv().ENERGY_ENABLED = state

		if state then
			local root = GetRoot()
			if root then
				root.CFrame = ENERGY_START_CFRAME
				task.wait(0.8)
			end

			task.spawn(function()
				while getgenv().ENERGY_ENABLED do
					pcall(Energy_Run)
					task.wait(5)
				end
			end)
		end
	end
})

ExploitsTab:Toggle({
	Title = "AutoFarm Strength",
	Value = false,
	Callback = function(state)
		getgenv().STRENGTH_ENABLED = state

		if state then
			local root = GetRoot()
			if root then
				root.CFrame = STRENGTH_START_CFRAME
				task.wait(0.8)
			end

			task.spawn(function()
				while getgenv().STRENGTH_ENABLED do
					pcall(Strength_Run)
					task.wait(10)
				end
			end)
		end
	end
})

