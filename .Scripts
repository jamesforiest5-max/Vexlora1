local function ApplySettingsSkybox(name)
	local SkyData = SkyboxAssets[name]
	if not SkyData then return end

	local SkyObj = Lighting:FindFirstChildOfClass("Sky") or Instance.new("Sky")
	SkyObj.Parent = Lighting

	SkyObj.SkyboxBk = SkyData[1]
	SkyObj.SkyboxDn = SkyData[2]
	SkyObj.SkyboxFt = SkyData[3]
	SkyObj.SkyboxLf = SkyData[4]
	SkyObj.SkyboxRt = SkyData[5]
	SkyObj.SkyboxUp = SkyData[6]
end

local function RestoreSettingsSkybox()
	local SkyObj = Lighting:FindFirstChildOfClass("Sky")
	if SkyObj then
		SkyObj:Destroy()
	end
end

VisualsTab:Dropdown({
	Title = "Select Sky",
	Values = SkyList,
	Value = CurrentSkybox,

	Callback = function(Option)
		CurrentSkybox = typeof(Option) == "table" and Option[1] or Option

		if CustomSkyEnabled then
			ApplySettingsSkybox(CurrentSkybox)
		end
	end
})

VisualsTab:Toggle({
	Title = "Custom Sky",
	Value = false,

	Callback = function(Value)
		CustomSkyEnabled = Value

		if Value then
			ApplySettingsSkybox(CurrentSkybox)
		else
			RestoreSettingsSkybox()
		end
	end
})

