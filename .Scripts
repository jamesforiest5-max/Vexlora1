local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local SelectedPlayer = nil

local function getPlayerByName(name)
	for _, p in pairs(Players:GetPlayers()) do
		if p.Name == name then
			return p
		end
	end
	return nil
end

local function updatePlayerList()
	local pl = {"None"}

	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			table.insert(pl, p.Name)
		end
	end

	return pl
end

local playerDropdown = FunTab:Dropdown({
	Title = "Select Player",
	Values = updatePlayerList(),
	Value = "None",

	Callback = function(selectedOption)
		local selNameStr

		if type(selectedOption) == "table" then
			selNameStr = selectedOption.Value or selectedOption[1] or tostring(selectedOption)
		else
			selNameStr = tostring(selectedOption)
		end

		if selNameStr == "None" or selNameStr == "" then
			SelectedPlayer = nil

			WindUI:Notify({
				Title = "Player Selection",
				Content = "No player selected",
				Duration = 2,
				Icon = "x"
			})

			return
		end

		SelectedPlayer = getPlayerByName(selNameStr)

		if SelectedPlayer then
			WindUI:Notify({
				Title = "Player Selected",
				Content = selNameStr .. " selected",
				Duration = 2,
				Icon = "check"
			})
		else
			WindUI:Notify({
				Title = "Error",
				Content = "Player '" .. selNameStr .. "' not found",
				Duration = 2,
				Icon = "message-circle-warning"
			})
		end
	end,
})

local function refreshDropdownOptions()
	if not playerDropdown then return end

	local newOptions = updatePlayerList()
	local oldSelected = SelectedPlayer and SelectedPlayer.Name or "None"

	playerDropdown:Refresh(newOptions)

	local stillExists = false
	for _, name in ipairs(newOptions) do
		if name == oldSelected then
			stillExists = true
			break
		end
	end

	if stillExists then
		playerDropdown.Value = oldSelected
		SelectedPlayer = getPlayerByName(oldSelected)
	else
		playerDropdown.Value = "None"
		SelectedPlayer = nil
	end

	WindUI:Notify({
		Title = "Player List",
		Content = "Player list refreshed",
		Duration = 2,
		Icon = "refresh-cw"
	})
end

local gotoPlayerToggle

gotoPlayerToggle = FunTab:Toggle({
	Title = "TP to Player",
	Icon = "map",
	Type = "Checkbox",
	Value = false,

	Callback = function(Value)
		if not Value then return end

		if SelectedPlayer then
			local targetChar = SelectedPlayer.Character or SelectedPlayer.CharacterAdded:Wait()
			local targetHRP = targetChar:WaitForChild("HumanoidRootPart", 10)

			local myChar = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
			local myHRP = myChar:WaitForChild("HumanoidRootPart", 10)

			if targetHRP and myHRP then
				getgenv().SwimMethod = true
				task.wait(1)
				myHRP.CFrame = targetHRP.CFrame
				getgenv().SwimMethod = false

				WindUI:Notify({
					Title = "Goto",
					Content = "Teleported to " .. SelectedPlayer.Name,
					Duration = 2,
					Icon = "map"
				})
			end
		else
			WindUI:Notify({
				Title = "Goto Error",
				Content = "Select a player first",
				Duration = 2,
				Icon = "message-circle-warning"
			})
		end

		if gotoPlayerToggle then
			gotoPlayerToggle:Set(false)
		end
	end,

})

FunTab:Button({
	Title = "Refresh Player List",
	Icon = "refresh-cw",

	Callback = function()
		refreshDropdownOptions()
	end,
})

FunTab:Divider()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local SelectedPlayer = nil

local function getPlayerList()
	local list = {"None"}

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			table.insert(list, player.Name)
		end
	end

	return list
end

local function getPlayerByName(name)
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Name == name then
			return player
		end
	end
end

local PlayerDropdown = FunTab:Dropdown({
	Title = "Select Player",
	Values = getPlayerList(),
	Value = "None",

	Callback = function(option)
		local name = type(option) == "table" and (option.Value or option[1]) or tostring(option)

		if name == "None" or name == "" then
			SelectedPlayer = nil
			return
		end

		SelectedPlayer = getPlayerByName(name)

		if SelectedPlayer then
			WindUI:Notify({
				Title = "Player Selected",
				Content = SelectedPlayer.Name,
				Duration = 2,
				Icon = "check"
			})
		end
	end
})

local spectateToggle
spectateToggle = FunTab:Toggle({
	Title = "Spectate Player",
	Icon = "eye",
	Type = "Checkbox",
	Value = false,

	Callback = function(Value)
		if Value then
			if SelectedPlayer and SelectedPlayer.Character and SelectedPlayer.Character:FindFirstChildOfClass("Humanoid") then
				workspace.CurrentCamera.CameraSubject = SelectedPlayer.Character:FindFirstChildOfClass("Humanoid")

				WindUI:Notify({
					Title = "Spectate",
					Content = "On: " .. SelectedPlayer.Name,
					Duration = 2,
					Icon = "eye"
				})
			else
				WindUI:Notify({
					Title = "Spectate",
					Content = "No target selected",
					Duration = 2,
					Icon = "alert"
				})

				if spectateToggle then
					spectateToggle:Set(false)
				end
			end
		else
			if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
				workspace.CurrentCamera.CameraSubject = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
			end

			WindUI:Notify({
				Title = "Spectate",
				Content = "Off",
				Duration = 2,
				Icon = "circle-plus"
			})
		end
	end
})

local viewInventory
viewInventory = FunTab:Toggle({
	Title = "View Inventory",
	Icon = "circle-plus",
	Type = "Checkbox",
	Value = false,

	Callback = function(Value)
		if not Value then return end

		if SelectedPlayer and SelectedPlayer:FindFirstChild("Backpack") then
			local items = {}

			for _, item in ipairs(SelectedPlayer.Backpack:GetChildren()) do
				table.insert(items, item.Name)
			end

			WindUI:Notify({
				Title = SelectedPlayer.Name .. "'s Inv",
				Content = (#items > 0 and table.concat(items, ", ") or "Empty"),
				Duration = 5,
				Icon = "circle-plus"
			})
		else
			WindUI:Notify({
				Title = "Inv",
				Content = "No target/backpack",
				Duration = 2,
				Icon = "alert"
			})
		end

		if viewInventory then
			viewInventory:Set(false)
		end
	end
})

FunTab:Divider()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

Config = Config or {}
Config.FlyEnabled = false
Config.FlySpeed = 5

local flyEnabled = false
local swimMethod = false
local speedConnection = nil
local CFloop = nil

local function handleSpeed()
    if not swimMethod then return end

    local character = player.Character
    if not character or not character.Parent then return end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")

    if not humanoid or not hrp or humanoid.Health <= 0 then return end

    humanoid:ChangeState(0)

    if flyEnabled then
        hrp.RotVelocity = Vector3.new(0, 0, 0)
        return
    end

    local moveDir = humanoid.MoveDirection

    if moveDir.Magnitude > 0 then
        local worldMoveVec = Vector3.new(moveDir.X, 0, moveDir.Z).Unit * 800

        if worldMoveVec.Magnitude == worldMoveVec.Magnitude then
            hrp.Velocity = Vector3.new(worldMoveVec.X, hrp.Velocity.Y, worldMoveVec.Z)
        end
    else
        hrp.Velocity = Vector3.new(0, hrp.Velocity.Y, 0)
    end

    hrp.RotVelocity = Vector3.new(0, 0, 0)
end

local function onCharacterAdded(char)
    if speedConnection then
        speedConnection:Disconnect()
        speedConnection = nil
    end

    local success = pcall(function()
        char:WaitForChild("Humanoid", 5)
        char:WaitForChild("HumanoidRootPart", 5)
    end)

    if not success then return end

    speedConnection = RunService.Stepped:Connect(function()
        local ok = pcall(handleSpeed)

        if not ok and speedConnection then
            speedConnection:Disconnect()
            speedConnection = nil
        end
    end)
end

if player.Character then
    onCharacterAdded(player.Character)
end

player.CharacterAdded:Connect(onCharacterAdded)

local function StartFly()
    if flyEnabled then return end

    flyEnabled = true
    swimMethod = true

    task.wait(0.2)

    local character = player.Character or player.CharacterAdded:Wait()
    if not character then return end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local head = character:FindFirstChild("Head")

    if not humanoid or not head then return end

    humanoid.PlatformStand = true
    head.Anchored = true

    if CFloop then
        CFloop:Disconnect()
    end

    CFloop = RunService.Heartbeat:Connect(function(deltaTime)
        if not flyEnabled or not character or not character.Parent then
            if CFloop then
                CFloop:Disconnect()
                CFloop = nil
            end
            return
        end

        camera = Workspace.CurrentCamera

        local moveDir = humanoid.MoveDirection
        local speed = 5 * deltaTime * 100

        local camCF = camera.CFrame
        local _, yRot, _ = camCF:ToOrientation()
        local uprightRot = CFrame.Angles(0, yRot, 0)

        local flatCamCF = CFrame.new(camCF.Position) * uprightRot
        local localInput = flatCamCF:VectorToObjectSpace(moveDir * speed)
        local worldMovement = camCF:VectorToWorldSpace(localInput)

        head.CFrame = CFrame.new(head.Position + worldMovement) * uprightRot
        camera.CameraSubject = head
    end)
end

local function StopFly()
    if not flyEnabled then return end

    flyEnabled = false
    swimMethod = false

    if CFloop then
        CFloop:Disconnect()
        CFloop = nil
    end

    local character = player.Character

    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local head = character:FindFirstChild("Head")

        if humanoid then
            humanoid.PlatformStand = false
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
            Workspace.CurrentCamera.CameraSubject = humanoid
        end

        if head then
            head.Anchored = false
        end
    end
end

FunTab:Toggle({
	Title = "Enable Fly",
	Icon = "plane",
	Value = false,

	Callback = function(state)
		if state then
			StartFly()
		else
			StopFly()
		end
	end,
})

--// WALKSPEED NO SLIDER

local speed = 300
local boostMultiplier = 2
local enhancedWalk = false

local character
local humanoid
local humanoidRootPart
local bodyGyro
local movementConnection
local freezeConnection
local animationTrack

local animation = Instance.new("Animation")
animation.AnimationId = "rbxassetid://656118852"

getgenv().SwimMethod = false

task.spawn(function()
    while task.wait() do
        if enhancedWalk then
            getgenv().SwimMethod = true

            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.FallingDown)
            end
        end
    end
end)

local function updateCharacterRefs()
    character = player.Character or player.CharacterAdded:Wait()
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
end

local function cleanup()
    if movementConnection then
        movementConnection:Disconnect()
        movementConnection = nil
    end

    if freezeConnection then
        freezeConnection:Disconnect()
        freezeConnection = nil
    end

    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end

    if animationTrack then
        animationTrack:Stop()
        animationTrack = nil
    end
end

local function setupMovement()
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 50000
    bodyGyro.D = 1000
    bodyGyro.CFrame = humanoidRootPart.CFrame
    bodyGyro.Parent = humanoidRootPart

    movementConnection = RunService.RenderStepped:Connect(function()
        if not enhancedWalk then return end

        local cam = workspace.CurrentCamera
        local dir = Vector3.zero
        local usingKeys = false

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            dir += Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
            usingKeys = true
        end

        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            dir -= Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
            usingKeys = true
        end

        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            dir -= cam.CFrame.RightVector
            usingKeys = true
        end

        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            dir += cam.CFrame.RightVector
            usingKeys = true
        end

        if not usingKeys then
            local md = humanoid.MoveDirection
            dir = Vector3.new(md.X, 0, md.Z)
        end

        local moveSpeed = speed

        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            moveSpeed = moveSpeed * boostMultiplier
        end

        if dir.Magnitude > 0 then
            dir = dir.Unit * moveSpeed
        end

        local currentY = humanoidRootPart.AssemblyLinearVelocity.Y
        local groundedY = math.clamp(currentY, -100, -2)

        humanoidRootPart.AssemblyLinearVelocity = Vector3.new(dir.X, groundedY, dir.Z)
        humanoidRootPart.RotVelocity = Vector3.zero
        humanoidRootPart.AssemblyAngularVelocity = Vector3.zero

        if dir.Magnitude > 0 then
            local look = dir.Unit

            bodyGyro.CFrame = CFrame.new(
                humanoidRootPart.Position,
                humanoidRootPart.Position + Vector3.new(look.X, 0, look.Z)
            )

            if animationTrack and not animationTrack.IsPlaying then
                animationTrack:Play()
            end
        else
            if animationTrack and animationTrack.IsPlaying then
                animationTrack:Stop()
            end
        end
    end)
end

local function startEnhancedWalk()
    enhancedWalk = true
    updateCharacterRefs()
    cleanup()

    humanoidRootPart.AssemblyLinearVelocity = Vector3.zero
    getgenv().SwimMethod = true

    freezeConnection = RunService.RenderStepped:Connect(function()
        if enhancedWalk and humanoidRootPart then
            getgenv().SwimMethod = true
            humanoidRootPart.AssemblyLinearVelocity = Vector3.zero
        end
    end)

    local animator = humanoid:FindFirstChildWhichIsA("Animator") or Instance.new("Animator", humanoid)

    animationTrack = animator:LoadAnimation(animation)
    animationTrack.Looped = true

    task.delay(2, function()
        if freezeConnection then
            freezeConnection:Disconnect()
            freezeConnection = nil
        end

        if enhancedWalk then
            setupMovement()
        end
    end)
end

local function stopEnhancedWalk()
    enhancedWalk = false
    cleanup()
    getgenv().SwimMethod = false
end

player.CharacterAdded:Connect(function()
    task.wait(1)
    updateCharacterRefs()

    if enhancedWalk then
        startEnhancedWalk()
    end
end)

FunTab:Toggle({
	Title = "Enable WalkSpeed",
	Icon = "zap",
	Value = false,

	Callback = function(state)
		if state then
			startEnhancedWalk()
		else
			stopEnhancedWalk()
		end
	end,
})

getgenv().killbring = false

FunTab:Toggle({
    Title = "KillBring",
    Icon = "map",
    Default = false,
    Callback = function(toggle)
        getgenv().killbring = toggle

        if toggle then
            task.spawn(function()
                while getgenv().killbring do
                    local speaker = game.Players.LocalPlayer
                    local speakerChar = speaker.Character
                    local speakerRoot = speakerChar and speakerChar:FindFirstChild("HumanoidRootPart")

                    if not speakerRoot then
                        task.wait()
                        continue
                    end

                    local radius = 6
                    local players = game.Players:GetPlayers()
                    local step = (2 * math.pi) / #players
                    local i = 0

                    for _, target in ipairs(players) do
                        if target ~= speaker and target.Character then
                            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                            local humanoid = target.Character:FindFirstChildOfClass("Humanoid")

                            if targetRoot then
                                if humanoid then
                                    humanoid.Sit = false
                                end

                                local angle = i * step
                                local offset = Vector3.new(math.cos(angle) * radius, 1, math.sin(angle) * radius)
                                targetRoot.CFrame = speakerRoot.CFrame + offset

                                i += 1
                            end
                        end
                    end

                    task.wait(0.3)
                end
            end)
        end
    end
})

local godModeEnabled = false
local safeZoneMoveConn = nil

UtilitiesTab:Toggle({
    Title = "God Mode",
    Icon = "feather",
    Callback = function(v)
        godModeEnabled = v

        local player = game:GetService("Players").LocalPlayer
        local safeZone = workspace:FindFirstChild("SafeZones")
            and workspace.SafeZones:FindFirstChild("lumberjackSafeZone")

        if v then
            if safeZoneMoveConn then
                safeZoneMoveConn:Disconnect()
            end

            safeZoneMoveConn = game:GetService("RunService").Heartbeat:Connect(function()
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")

                if safeZone and root then
                    safeZone.Position = root.Position
                end
            end)
        else
            if safeZoneMoveConn then
                safeZoneMoveConn:Disconnect()
                safeZoneMoveConn = nil
            end
        end
    end
})

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

local FreeCamEnabled = false
local FreeCamConnection = nil
local MouseLook = false

local speed = 2
local sensitivity = 0.25
local rotX = 0
local rotY = 0

local function DisableFreeCam()
	FreeCamEnabled = false

	if FreeCamConnection then
		FreeCamConnection:Disconnect()
		FreeCamConnection = nil
	end

	camera.CameraType = Enum.CameraType.Custom
	UIS.MouseBehavior = Enum.MouseBehavior.Default
	UIS.MouseIconEnabled = true

	local char = player.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	local root = char and char:FindFirstChild("HumanoidRootPart")

	if hum then
		camera.CameraSubject = hum
	end

	if root then
		root.Anchored = false
	end
end

local function EnableFreeCam()
	FreeCamEnabled = true

	local char = player.Character or player.CharacterAdded:Wait()
	local root = char:WaitForChild("HumanoidRootPart")

	root.Anchored = true
	camera.CameraType = Enum.CameraType.Scriptable

	UIS.MouseBehavior = Enum.MouseBehavior.Default
	UIS.MouseIconEnabled = true

	local _, y, _ = camera.CFrame:ToOrientation()
	rotX = 0
	rotY = math.deg(y)

	if FreeCamConnection then
		FreeCamConnection:Disconnect()
	end

	FreeCamConnection = RunService.RenderStepped:Connect(function()
		if not FreeCamEnabled then return end

		local camCF =
			CFrame.new(camera.CFrame.Position)
			* CFrame.Angles(0, math.rad(rotY), 0)
			* CFrame.Angles(math.rad(rotX), 0, 0)

		local move = Vector3.zero

		if UIS:IsKeyDown(Enum.KeyCode.W) then move += camCF.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.S) then move -= camCF.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.A) then move -= camCF.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D) then move += camCF.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.E) then move += Vector3.new(0, 1, 0) end
		if UIS:IsKeyDown(Enum.KeyCode.Q) then move -= Vector3.new(0, 1, 0) end

		camera.CFrame = camCF + move * speed
	end)
end

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end

	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		MouseLook = true
		UIS.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
	end

	if input.KeyCode == Enum.KeyCode.RightShift then
		DisableFreeCam()
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		MouseLook = false
		UIS.MouseBehavior = Enum.MouseBehavior.Default
	end
end)

UIS.InputChanged:Connect(function(input)
	if FreeCamEnabled and MouseLook and input.UserInputType == Enum.UserInputType.MouseMovement then
		rotX = math.clamp(rotX - input.Delta.Y * sensitivity, -80, 80)
		rotY = rotY - input.Delta.X * sensitivity
	end
end)

UtilitiesTab:Toggle({
	Title = "FreeCam",
	Icon = "camera",
	Value = false,

	Callback = function(Value)
		if Value then
			EnableFreeCam()
		else
			DisableFreeCam()
		end
	end,
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedNoClip = false
getgenv().CertifiedNoClipConnection = nil

local function SetNoClip(state)
    local char = LocalPlayer.Character
    if not char then return end

    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CanCollide = not state
        end
    end
end

UtilitiesTab:Toggle({
    Title = "NoClip",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().CertifiedNoClip = state

        if state then
            if getgenv().CertifiedNoClipConnection then
                getgenv().CertifiedNoClipConnection:Disconnect()
            end

            getgenv().CertifiedNoClipConnection = RunService.Stepped:Connect(function()
                if getgenv().CertifiedNoClip then
                    SetNoClip(true)
                end
            end)
        else
            if getgenv().CertifiedNoClipConnection then
                getgenv().CertifiedNoClipConnection:Disconnect()
                getgenv().CertifiedNoClipConnection = nil
            end

            SetNoClip(false)
        end
    end
})

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)

    if getgenv().CertifiedNoClip then
        SetNoClip(true)
    end
end)
            
UtilitiesTab:Divider()



local antiRagdollConnection = nil
local antiJumpConnection = nil

UtilitiesTab:Toggle({
    Title = "Anti Fall Damage",
    Desc = "Player",
    Icon = "feather",
    Type = "Checkbox",
    Callback = function(v)
        local pl = game:GetService("Players").LocalPlayer

        if antiRagdollConnection then
            antiRagdollConnection:Disconnect()
            antiRagdollConnection = nil
        end

        if antiJumpConnection then
            antiJumpConnection:Disconnect()
            antiJumpConnection = nil
        end

        if v then
            antiRagdollConnection = game:GetService("RunService").Stepped:Connect(function()
                local char = pl.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")

                if hum and hum.FloorMaterial == Enum.Material.Air then
                    if hum.Health < hum.MaxHealth then
                        hum.Health = hum.MaxHealth
                    end
                end
            end)
        end
    end
})

local antiCombatLoop = false
local combatThread = nil

UtilitiesTab:Toggle({
    Title = "Anti Combat",
    Desc = "Player",
    Icon = "feather",
    Type = "Checkbox",
    Callback = function(v)
        antiCombatLoop = v

        local plr = game:GetService("Players").LocalPlayer
        local settings = plr:FindFirstChild("Settings")
        local sObj = settings and settings:FindFirstChild("Settings")

        if v then
            combatThread = task.spawn(function()
                while antiCombatLoop do
                    if sObj and sObj:GetAttribute("Combat") == true then
                        sObj:SetAttribute("Combat", false)
                    end
                    task.wait(0.05)
                end
            end)
        else
            antiCombatLoop = false
            combatThread = nil
        end
    end
})

local antiKnockoutLoop = false
local knockoutThread = nil

UtilitiesTab:Toggle({
    Title = "Anti Knockout",
    Desc = "Player",
    Icon = "feather",
    Type = "Checkbox",
    Callback = function(v)
        antiKnockoutLoop = v

        local plr = game:GetService("Players").LocalPlayer
        local settings = plr:FindFirstChild("Settings")
        local sObj = settings and settings:FindFirstChild("Settings")

        if v then
            knockoutThread = task.spawn(function()
                while antiKnockoutLoop do
                    if sObj and sObj:GetAttribute("KnockedOut") == true then
                        sObj:SetAttribute("KnockedOut", false)
                    end
                    task.wait(0.2)
                end
            end)
        else
            antiKnockoutLoop = false
            knockoutThread = nil
        end
    end
})

local modState = {
    infDamage = false,
    fastReload = false,
    antiJam = false,
    autoActivate = false,
    noRecoil = false,
    fastEquip = false,
    fastShoot = false,
}

local function getAllGuns()
    local guns = {}

    local function scan(container)
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Settings") then
                table.insert(guns, tool)
            end
        end
    end

    local player = game.Players.LocalPlayer

    if player.Backpack then
        scan(player.Backpack)
    end

    if player.Character then
        scan(player.Character)
    end

    return guns
end

local function applyGunMods(gun, mods)
    local settings = gun:FindFirstChild("Settings")
    if not settings or not settings:IsA("ModuleScript") then
        return
    end

    local gunData = require(settings)

    if type(gunData) ~= "table" then
        return
    end

    if mods.infDamage then
        for _, stat in ipairs({
            "headDamage",
            "torsoDamage",
            "armDamage",
            "legDamage",
            "handDamage",
            "footDamage",
            "vestDamage",
            "hatDamage"
        }) do
            if gunData[stat] then
                gunData[stat] = math.huge
            end
        end
    end

    if mods.fastReload then
        if gunData.reloadAnimation then gunData.reloadAnimation = 0 end
        if gunData.reloadSound then gunData.reloadSound = 0 end
    end

    if mods.antiJam then
        if gunData.jamChance then gunData.jamChance = 0 end
        if gunData.jamIncrease then gunData.jamIncrease = 0 end
    end

    if mods.autoActivate then
        if gunData.fireMode then gunData.fireMode = "auto" end
        if gunData.autoCooldown then gunData.autoCooldown = 0.01 end
    end

    if mods.noRecoil then
        if gunData.recoil then gunData.recoil = 0 end
        if gunData.spread then gunData.spread = 0 end
    end

    if mods.fastEquip then
        if gunData.equipAnimation then gunData.equipAnimation = 0 end
        if gunData.unequipAnimation then gunData.unequipAnimation = 0 end
        if gunData.sprintAnimation then gunData.sprintAnimation = 0 end
        if gunData.raiseAnimation then gunData.raiseAnimation = 0 end
        if gunData.pointAnimation then gunData.pointAnimation = 0 end
    end

    if mods.fastShoot then
        if gunData.semiCooldown then gunData.semiCooldown = 0 end
        if gunData.autoCooldown then gunData.autoCooldown = 0 end
    end
end

local function applyAllMods()
    for _, gun in ipairs(getAllGuns()) do
        applyGunMods(gun, modState)
    end
end

UtilitiesTab:Button({
    Title = "Fast Reload",
    Color = Color3.fromRGB(13, 105, 172),
    Callback = function(Value)
        modState.fastReload = Value
        applyAllMods()
    end,
})

