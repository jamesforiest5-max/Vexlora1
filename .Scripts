getgenv().ENERGY_ENABLED = false
getgenv().STRENGTH_ENABLED = false

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local ENERGY_START_CFRAME = CFrame.new(2731.9, 288.5, 1750.6)
local STRENGTH_START_CFRAME = CFrame.new(2735.0, 288.2, 1736.7)

local function GetRoot()
	local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart", 10)
end

local function FirePrompt(prompt, name)
	if not prompt then
		warn((name or "Prompt") .. ": No prompt found")
		return
	end

	pcall(function()
		prompt.Enabled = true
		prompt.HoldDuration = 0
		prompt.MaxActivationDistance = 100
		prompt.RequiresLineOfSight = false
	end)

	task.wait(0.25)

	local fired = false

	if fireproximityprompt then
		fired = pcall(function()
			fireproximityprompt(prompt)
		end)
	end

	if not fired then
		pcall(function()
			prompt:InputHoldBegin()
			task.wait(0.35)
			prompt:InputHoldEnd()
		end)
	end

	task.wait(0.15)

	pcall(function()
		prompt:InputHoldBegin()
		task.wait(0.15)
		prompt:InputHoldEnd()
	end)
end

------------------------------------------------
-- ENERGY CODE
------------------------------------------------

local function Energy_Run()
	local root = GetRoot()
	if not root then return end

	local fitness = workspace:FindFirstChild("BrickhouseFitness")
	if not fitness then return warn("Energy: BrickhouseFitness not found") end

	local targetObj = fitness:FindFirstChild("Treadmill OBJ")
	if not targetObj then return warn("Energy: Treadmill OBJ not found") end

	local prompt = targetObj:FindFirstChildWhichIsA("ProximityPrompt", true)
	if not prompt then return warn("Energy: Treadmill prompt not found") end

	local parent = prompt.Parent
    local part = (parent and parent:IsA("BasePart") and parent)
	    or targetObj.PrimaryPart
	    or targetObj:FindFirstChildWhichIsA("BasePart", true)

    if part then
	root.CFrame = part.CFrame + Vector3.new(0, 2, 0)
	task.wait(0.4)
    end

    FirePrompt(prompt, "Energy")
end

------------------------------------------------
-- STRENGTH CODE
------------------------------------------------

local function Strength_Run()
	local root = GetRoot()
	if not root then return end

	local fitness = workspace:FindFirstChild("BrickhouseFitness")
	if not fitness then return warn("Strength: BrickhouseFitness not found") end

	local targetObj = fitness:FindFirstChild("WorkoutBench")
	if not targetObj then return warn("Strength: WorkoutBench not found") end

	local prompt =
		targetObj:FindFirstChildWhichIsA("ProximityPrompt", true)
		or targetObj:FindFirstChild("Interaction", true)

	if not prompt then return warn("Strength: WorkoutBench prompt not found") end

	local parent = prompt.Parent
    local part = (parent and parent:IsA("BasePart") and parent)
	    or targetObj.PrimaryPart
	    or targetObj:FindFirstChildWhichIsA("BasePart", true)

    if part then
	root.CFrame = part.CFrame + Vector3.new(0, 2, 0)
	task.wait(0.4)
    end

    FirePrompt(prompt, "Strength")
end

