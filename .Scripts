local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local infiniteMoneyEnabled = false
local infiniteMoneyThread = nil

local function getInfiniteMoneyGuiElements()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local mainGui = playerGui:WaitForChild("MainGUI")
    local closetFrame = mainGui:WaitForChild("closetFrame")
    local apparelFrame = mainGui:WaitForChild("phillyApparelFrame")

    return {
        HatsFrame = closetFrame.stockFrame:WaitForChild("Hat"),
        WearButton = closetFrame.productFrame.contentFrame:WaitForChild("wearButton"),
        NoneButton = apparelFrame.stockFrame.Content3:WaitForChild("None"),
        PurchaseButton = apparelFrame.productFrame.contentFrame:WaitForChild("purchaseButton"),
        ShopBandana = apparelFrame.stockFrame.Content3:WaitForChild("Blue Head Bandana"),
    }
end

local function waitForOwnedBandana(hatsFrame)
    local owned = hatsFrame:FindFirstChild("Blue Head Bandana")
    if owned then
        return owned
    end

    repeat
        RunService.Heartbeat:Wait()
        owned = hatsFrame:FindFirstChild("Blue Head Bandana")
    until owned or not infiniteMoneyEnabled

    return owned
end

local function infiniteMoneyLoop()
    local success = pcall(function()
        if not LocalPlayer or not replicatesignal then
            return
        end

        local ui = getInfiniteMoneyGuiElements()
        local hatsFrame = ui.HatsFrame

        if not hatsFrame:FindFirstChild("Blue Head Bandana") then
            replicatesignal(ui.ShopBandana.MouseButton1Down, 0, 0)
            RunService.Heartbeat:Wait()
            replicatesignal(ui.PurchaseButton.MouseButton1Down, 0, 0)
        end

        local blueBandana = waitForOwnedBandana(hatsFrame)
        if not blueBandana then
            return
        end

        while infiniteMoneyEnabled do
            replicatesignal(blueBandana.MouseButton1Down, 0, 0)
            RunService.Heartbeat:Wait()

            replicatesignal(ui.WearButton.MouseButton1Down, 0, 0)
            RunService.Heartbeat:Wait()

            replicatesignal(ui.NoneButton.MouseButton1Down, 0, 0)
            RunService.Heartbeat:Wait()

            replicatesignal(ui.PurchaseButton.MouseButton1Down, 0, 0)
            RunService.Heartbeat:Wait()
        end
    end)

    if not success and infiniteMoneyEnabled then
        task.wait(1)
    end
end
            
ExploitsTab:Toggle({
    Title = "Infinite Money",
    Desc = "Click on Infinite Money",
    Icon = "sun",
    Type = "Checkbox",
    Callback = function(state)
        infiniteMoneyEnabled = state

        if infiniteMoneyEnabled and (not infiniteMoneyThread or coroutine.status(infiniteMoneyThread) == "dead") then
            infiniteMoneyThread = task.spawn(infiniteMoneyLoop)
        end
    end,
})
ExploitsTab:Button({
    Title = "Money Counter Dupe",
    Callback = function()
        local player = game.Players.LocalPlayer
        local machines = workspace:WaitForChild("MoneyCounterMachines"):GetChildren()

        local specialMachine = machines[4]
        local specialPickup = specialMachine and specialMachine:FindFirstChild("Base") and specialMachine.Base:FindFirstChild("Pickup")
        local specialPickupInteraction = specialPickup and specialPickup:FindFirstChild("Interaction") or nil

        local usablePrompts = {}

        for _, machine in ipairs(machines) do
            if machine:FindFirstChild("Base") then
                local pickupPart = machine.Base:FindFirstChild("Pickup")
                if pickupPart and pickupPart:FindFirstChild("Interaction") then
                    local pickupPrompt = pickupPart.Interaction
                    if pickupPrompt:IsA("ProximityPrompt") and pickupPrompt ~= specialPickupInteraction then
                        pickupPrompt.Enabled = false
                        pickupPrompt.HoldDuration = 0
                        pickupPrompt.Exclusivity = Enum.ProximityPromptExclusivity.AlwaysShow
                    end
                end

                local interactPart = machine.Base:FindFirstChild("Interact")
                if interactPart and interactPart:FindFirstChild("Interaction") then
                    local interactionPrompt = interactPart.Interaction
                    if interactionPrompt:IsA("ProximityPrompt") then
                        interactionPrompt.HoldDuration = 0
                        interactionPrompt.Exclusivity = Enum.ProximityPromptExclusivity.AlwaysShow
                    end

                    table.insert(usablePrompts, interactPart.Interaction)
                end
            end
        end

        if specialPickupInteraction and specialPickupInteraction:IsA("ProximityPrompt") then
            specialPickupInteraction.HoldDuration = 0
            specialPickupInteraction.Exclusivity = Enum.ProximityPromptExclusivity.AlwaysShow
            table.insert(usablePrompts, specialPickupInteraction)
        end
    end,
})

